{
  "manifest_version": 3,
  "name": "CityHealth Companion",
  "version": "1.0.0",
  "description": "Accès rapide au triage IA, recherche de professionnels et alertes SOS don de sang.",
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "https://hozjbchgaucbfqumrhhs.supabase.co/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
